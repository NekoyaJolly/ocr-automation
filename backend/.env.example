BACKEND_PROJECT_ID=your-gcp-project-id
BACKEND_LOG_LEVEL=INFO
BACKEND_GEMINI_API_KEY_SECRET_NAME=gemini-api-key

# Gemini モデル名 (デフォルト: gemini-3.1-pro-preview)
BACKEND_GEMINI_MODEL=gemini-3.1-pro-preview

FIRESTORE_EMULATOR_HOST=localhost:8200

# ローカル開発用 Gemini API キー (本番は Secret Manager を使う)
BACKEND_GEMINI_API_KEY=your-gemini-api-key-here
